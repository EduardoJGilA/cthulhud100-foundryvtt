<div class="dice-roll no-dice-formula{{#unless checkRevealed}} keeper-only-block{{/unless}}" data-action="expandRoll">
  <div class="dice-result">
    <div class="dice-tooltip">
      <div class="wrapper">
        <section class="tooltip-part">
          <div class="dice">
            {{#if flavor}}
              <div style="font-size: var(--font-size-12);">{{flavor}}</div>
            {{/if}}
            <header class="part-header flexrow">
              {{#if diceGroup.rollMethod.icon}}
                <span class="part-method" data-tooltip aria-label="{{localize diceGroup.rollMethod.label}}">
                  {{{diceGroup.rollMethod.icon}}}
                </span>
              {{/if}}
              <span class="part-formula">
                {{#if (eq 1 diceGroup.decaders.length)}}
                  1 {{localize 'Cd100.TensDie'}}
                {{else}}
                  {{diceGroup.decaders.length}} {{localize 'Cd100.TensDice'}} ({{bonusType}})
                {{/if}}
              </span>
              <span class="part-total">{{diceGroup.decader}}</span>
            </header>
            <ol class="dice-rolls">
              {{#each diceGroup.decaders}}
                <li class="roll die d10{{#unless this.active}} discarded{{/unless}}">{{this.result}}</li>
              {{/each}}
            </ol>
          </div>
        </section>
        <section class="tooltip-part">
          <div class="dice">
            <header class="part-header flexrow">
              {{#if diceGroup.rollMethod.icon}}
                <span class="part-method" data-tooltip aria-label="{{localize diceGroup.rollMethod.label}}">
                  {{{diceGroup.rollMethod.icon}}}
                </span>
              {{/if}}
              <span class="part-formula">
                {{localize 'Cd100.UnitsDie'}}
              </span>
              <span class="part-total">{{diceGroup.unit}}</span>
            </header>
            <ol class="dice-rolls">
              <li class="roll die d10">{{diceGroup.unit}}</li>
            </ol>
          </div>
        </section>

        <div>{{diceGroup.resultType}}</div>

        <div class="owner-and-keeper-block coc7-card-buttons flexrow" data-actor-uuid="{{actorUuid}}">
          {{#if buttons.luckRegular}}
            <button data-action="luck" data-luck-spend="{{buttons.luckRegular}}">{{localize 'Cd100.SpendLuck' luckNeededValue=buttons.luckRegular}}</button>
          {{/if}}
          {{#if buttons.luckHard}}
            <button data-action="luck" data-luck-spend="{{buttons.luckHard}}">{{localize 'Cd100.IncreaseSuccessLevel'}}: {{localize 'Cd100.HardDifficulty'}} - {{buttons.luckHard}} {{localize 'Cd100.Luck'}}.</button>
          {{/if}}
          {{#if buttons.luckExtreme}}
            <button data-action="luck" data-luck-spend="{{buttons.luckExtreme}}">{{localize 'Cd100.IncreaseSuccessLevel'}}: {{localize 'Cd100.ExtremeDifficulty'}} - {{buttons.luckExtreme}} {{localize 'Cd100.Luck'}}.</button>
          {{/if}}
          {{#if buttons.luckCritical}}
            <button data-action="luck" data-luck-spend="{{buttons.luckCritical}}">{{localize 'Cd100.IncreaseSuccessLevel'}}: {{localize 'Cd100.CriticalDifficulty'}} - {{buttons.luckCritical}} {{localize 'Cd100.Luck'}}.</button>
          {{/if}}
          {{#if buttons.addBonus2}}
            <button data-action="bonus" data-quantity="2">{{localize 'Cd100.PoolAddTwoBonus'}}</button>
          {{/if}}
          {{#if buttons.addBonus1}}
            <button data-action="bonus" data-quantity="1">{{localize 'Cd100.PoolAddOneBonus'}}</button>
          {{/if}}
          {{#if buttons.addPenalty1}}
            <button data-action="bonus" data-quantity="-1">{{localize 'Cd100.PoolAddOnePenalty'}}</button>
          {{/if}}
          {{#if buttons.addPenalty2}}
            <button data-action="bonus" data-quantity="-2">{{localize 'Cd100.PoolAddTwoPenalty'}}</button>
          {{/if}}
        </div>
      </div>
    </div>
    <h4 class="dice-total{{#if diceGroup.isCritical}} critical{{else if diceGroup.isFumble}} fumble{{else if diceGroup.isRegularFailure}} failure{{else if diceGroup.isSpecialSuccess}} success-special{{else if diceGroup.isRegularSuccess}} success-regular{{/if}}">{{diceGroup.total}} {{diceGroup.resultType}}{{#if diceGroup.flatDiceModifier}} ({{#if (gt diceGroup.flatDiceModifier 0)}}+{{/if}}{{diceGroup.flatDiceModifier}}){{/if}}</h4>
    {{#if hasMalfunction}}
      <h4 class="coc7-malfunction">{{malfunctionTxt}}</h4>
    {{/if}}
    {{#if rollDamage}}
      <div class="owner-and-keeper-block coc7-card-buttons flexrow" data-actor-uuid="{{actorUuid}}">
        <button data-action="rollMeleeDamage">{{localize 'Cd100.RollDamage'}}</button>
      </div>
    {{/if}}
  </div>
</div>
{{#unless checkRevealed}}
  <div class="coc7-card-buttons keeper-only-block with-top-gap flexrow" style="order: 3; gap: 0.375rem;">
    <button data-action="revealCheck">{{localize 'Cd100.RevealCheck'}}</button>
    {{#if (and canLuckAwayConsequences badConsequence)}}
      <button data-action="useLuckForWeaponFailure">{{localize 'Cd100.UseLuckForWeaponFailure'}}</button>
    {{/if}}
  </div>
{{else if (and canLuckAwayConsequences badConsequence)}}
  <div class="coc7-card-buttons owner-and-keeper-block with-top-gap flexrow" data-actor-uuid="{{actorUuid}}" style="order: 3">
    <button data-action="useLuckForWeaponFailure">{{localize 'Cd100.UseLuckForWeaponFailure'}}</button>
  </div>
{{/unless}}
