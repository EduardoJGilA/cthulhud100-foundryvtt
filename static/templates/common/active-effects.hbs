<ul class="item-list effects-list">
  {{#each effects as |category sid|}}
    {{#unless category.hidden}}
      <li class="item items-header" data-effect-type="{{category.type}}">
        <h3 class="section-heading effect-name">{{localize category.label}}</h3>
        <div class="effect-source">{{localize 'Cd100.Source'}}</div>
        <div class="effect-duration">{{localize 'Cd100.Duration'}}</div>
        <div class="item-controls effect-controls">
          {{#if @root.editable}}
            <a class="item-control effect-control" data-action="create" data-tooltip="Cd100.Create">
              <i class="fa-regular fa-plus-circle"></i> {{localize 'Cd100.Add'}}
            </a>
          {{/if}}
        </div>
      </li>
      {{#if category.info}}
        <li>
          <ul class="info">
            {{#each category.info}}
              <li class="notification info">{{this}}</li>
            {{/each}}
          </ul>
        </li>
      {{/if}}
      {{#each category.effects as |effect|}}
        <li class="item effect" data-effect-uuid="{{effect.uuid}}">
          <div class="effect-identifier" data-tooltip="{{effect.readable}}">
            <div class="item-image" style="background-image: url('{{effect.img}}')"></div>
            <h4 class="item-name effect-name">{{effect.name}}</h4>
          </div>
          <div class="effect-source">{{{effect.source}}}</div>
          <div class="effect-duration">{{effect.duration}}</div>
          <div class="item-controls effect-controls">
            {{#if @root.editable}}
              <a class="item-control effect-control" data-action="toggle" data-tooltip="{{#if effect.disabled}}Cd100.Enable{{else}}Cd100.Disable{{/if}}">
                <i class="fa-solid{{#if effect.disabled}} fa-check{{else}} fa-times{{/if}}"></i>
              </a>
              <a class="item-control effect-control" data-action="edit" data-tooltip="Cd100.Edit">
                <i class="fa-solid fa-edit"></i>
              </a>
              <a class="item-control effect-control" data-action="delete" data-tooltip="Cd100.Delete">
                <i class="fa-solid fa-trash"></i>
              </a>
            {{/if}}
          </div>
        </li>
      {{/each}}
    {{/unless}}
  {{/each}}
</ul>