<div class="flexcol">
  {{#if cardTypes}}
    <div class="form-group">
      <label>{{localize 'Cd100.CardType'}}</label>
      <select name="cardType">
        {{selectOptions cardTypes selected=options.cardType localize=true}}
      </select>
    </div>
  {{/if}}

  {{#if askValue}}
    <div class="form-group">
      <label>{{localize 'Cd100.RollThreshold'}}</label>
      <input type="number" name="threshold" value="{{options.threshold}}" />
    </div>
  {{/if}}

  {{#unless hideDifficulty}}
    <div class="form-group">
      <label>{{localize 'Cd100.RollDifficulty'}}</label>
      <select name="difficulty">
        {{selectOptions difficultyTypes selected=options.difficulty localize=true valueAttr='key' labelAttr='val'}}
      </select>
    </div>
  {{/unless}}

  {{#if allowFlatDiceModifier}}
    <div class="form-group">
      <label>{{localize 'Cd100.FlatDiceModifier'}}</label>
      <input type="number" name="flatDiceModifier" value="{{options.flatDiceModifier}}" />
    </div>
  {{/if}}

  {{#if allowFlatThresholdModifier}}
    {{!-- Cthulhu d100 circumstance modifiers. A shortcut that fills in the
          threshold modifier below, which is the value actually submitted. --}}
    {{!-- Illumination scales the skill: half in gloom, a quarter in near or
          total darkness, with total darkness also capped at min(POD, INT) x3.
          Worked out against the threshold when the dialog is submitted. --}}
    <div class="form-group">
      <label>{{localize 'Cd100.Illumination'}}</label>
      <select name="illumination">
        {{selectOptions illuminationLevels selected='normal' localize=true valueAttr='key' labelAttr='val'}}
      </select>
    </div>

    <div class="form-group">
      <label>{{localize 'Cd100.Circumstances'}}</label>
      <select name="circumstanceModifier" data-cd100-circumstance>
        {{selectOptions circumstanceModifiers selected=0 localize=true valueAttr='key' labelAttr='val'}}
      </select>
    </div>

    <div class="form-group">
      <label>{{localize 'Cd100.FlatModifier'}}</label>
      <input type="number" name="flatThresholdModifier" value="{{options.flatThresholdModifier}}" />
    </div>
  {{/if}}

  {{!-- Cthulhu d100 has no bonus or penalty dice. The rulebook adjusts a check
        with circumstance modifiers and illumination, both of which move the
        threshold, never by adding tens dice to the pool. The pool machinery is
        still present for compatibility but is no longer offered here. --}}
</div>
